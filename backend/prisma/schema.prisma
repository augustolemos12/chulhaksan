// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//Generator para crear el diagrama ERD
generator erd {
  provider = "prisma-erd-generator"
  output   = "./erd/ERD.pdf"
  format   = "pdf"
}

//
// ENUMS
//

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum StudentCategory {
  CHILD
  ADULT
}

enum PaymentMethod {
  ONLINE
  CASH
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Belt {
  WHITE
  WHITE_YELLOW

  YELLOW
  GREEN_STRIPE
  GREEN
  BLUE_STRIPE

  BLUE
  RED_STRIPE
  RED
  BLACK_STRIPE

  DAN
}

enum FeeStatus {
  PENDING
  PAID
  FULL_YEAR
  OVERDUE
}

//
// USERS
//

model User {
  id       Int    @id @default(autoincrement())
  dni      String @unique
  password String

  role   Role
  status UserStatus @default(ACTIVE)

  mustChangePassword Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  teacher Teacher?
  student Student?
}

//
// TEACHERS
//

model Teacher {
  id     Int @id @default(autoincrement())
  userId Int @unique

  firstName String
  lastName  String
  phone     String?
  email     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  gyms    Gym[]
  students Student[]
}

//
// GYMS
//

model Gym {
  id   Int    @id @default(autoincrement())
  name String

  teacherId Int?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  teacher Teacher? @relation(fields: [teacherId], references: [id], onDelete: Restrict)

  students Student[]

  classPlans  ClassPlan[]
  attendances Attendance[]

  @@index([teacherId])
  @@index([deletedAt])
  @@index([isActive])

}

//
// STUDENTS
//

model Student {
  id     Int @id @default(autoincrement())
  userId Int @unique

  firstName String
  lastName  String

  category StudentCategory

  phone   String?
  email   String?
  address String?

  gymId     Int
  teacherId Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  currentBelt Belt @default(WHITE)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  gym     Gym     @relation(fields: [gymId], references: [id])
  teacher Teacher @relation(fields: [teacherId], references: [id])

  belts       StudentBelt[]
  attendances Attendance[]
  fees        Fee[]
  formAccess  StudentFormAccess[]

  @@index([teacherId])
  @@index([gymId])
}

//
// BELTS (HISTORIAL REAL)
//

model StudentBelt {
  id Int @id @default(autoincrement())

  studentId Int
  belt      Belt

  achievedAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

//
// FEES (CUOTAS)
//

model Fee {
  id Int @id @default(autoincrement())

  studentId Int

  month Int
  year  Int

  status FeeStatus @default(PENDING)

  baseAmount  Int
  finalAmount Int

  dueDate DateTime

  paidAt DateTime?

  paymentMethod PaymentMethod?

  lateFeeApplied Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  student  Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  payments Transaction[]

  @@unique([studentId, month, year])
  @@index([studentId])
}

model FeeConfig {
  id Int @id @default(autoincrement())

  baseAmount Int
  lateFee    Int

  validFrom DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// PAYMENTS (TRANSACCIONES)
//

model Transaction {
  id Int @id @default(autoincrement())

  feeId Int

  externalId   String? // MP id
  preferenceId String?

  status PaymentStatus

  rawData Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  paidAt    DateTime?

  fee Fee @relation(fields: [feeId], references: [id], onDelete: Cascade)
}

//
// ATTENDANCE
//

model Attendance {
  id Int @id @default(autoincrement())

  studentId Int
  gymId     Int

  date    DateTime
  present Boolean

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  gym     Gym     @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([gymId])
  @@index([date])
}

//
// CLASS PLAN (CLASES POR MES)
//

model ClassPlan {
  id Int @id @default(autoincrement())

  gymId Int

  month Int
  year  Int

  totalClasses Int

  gym Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@unique([gymId, month, year])
}

//
// FORMS (CONTENIDO)
//

model Form {
  id Int @id @default(autoincrement())

  title String
  url   String

  requiredBelt Belt

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  studentFormAccesses StudentFormAccess[]
}

model StudentFormAccess {
  id Int @id @default(autoincrement())

  studentId Int
  formId    Int

  unlockedAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  form    Form    @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@unique([studentId, formId])
}

//
// EVENTS (EVENTO DEL MES)
//

model Event {
  id Int @id @default(autoincrement())

  title    String
  imageUrl String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
